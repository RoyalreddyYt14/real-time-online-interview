# OAuth Credentials - Replace with your actual credentials
# Get these from Google Cloud Console, GitHub, and Azure Portal

# Google OAuth (from console.cloud.google.com)
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# GitHub OAuth (from github.com/settings/developers)
GITHUB_CLIENT_ID=your-github-client-id-here
GITHUB_CLIENT_SECRET=your-github-client-secret-here

# Microsoft OAuth (from portal.azure.com)
MICROSOFT_CLIENT_ID=your-microsoft-client-id-here
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret-here

# Application URL (for OAuth redirect URIs)
APP_URL=http://localhost:5000

# Admin Credentials
ADMIN_EMAIL=your-admin-email@example.com
ADMIN_PASSWORD=your-admin-password

# Email Settings (for notifications)
# You may set either MAIL_USERNAME / MAIL_PASSWORD or SMTP_USERNAME / SMTP_PASSWORD.
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
# Optional Gmail OAuth2 support
# GMAIL_OAUTH2_ENABLED=True
# GMAIL_OAUTH2_CLIENT_ID=your-client-id
# GMAIL_OAUTH2_CLIENT_SECRET=your-client-secret
# GMAIL_OAUTH2_TOKEN_FILE=./gmail_token.json
